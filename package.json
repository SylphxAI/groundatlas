{
  "name": "groundatlas",
  "version": "0.1.0",
  "description": "Source-grounded knowledge maps for humans and agents.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/SylphxAI/groundatlas#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SylphxAI/groundatlas.git"
  },
  "bugs": {
    "url": "https://github.com/SylphxAI/groundatlas/issues"
  },
  "keywords": [
    "agents",
    "documentation",
    "knowledge-map",
    "source-grounding",
    "cli",
    "ssot"
  ],
  "bin": {
    "groundatlas": "./dist/cli.js",
    "ga": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "PROJECT.md"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --target=node --format=esm --outfile=dist/cli.js && node scripts/fix-shebang.mjs",
    "check": "bun run typecheck && bun test && biome check . && bun run validate:manifest && bun run build && node dist/cli.js --help && node dist/cli.js update && node dist/cli.js audit",
    "validate:manifest": "node scripts/validate-project-manifest.mjs",
    "dev": "bun run src/cli.ts",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "groundatlas:update": "bun run src/cli.ts update",
    "groundatlas:audit": "bun run src/cli.ts audit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.12"
}
