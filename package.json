{
  "name": "groundatlas",
  "version": "0.1.0",
  "description": "Source-grounded repository control plane for humans and agents.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/SylphxAI/groundatlas#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SylphxAI/groundatlas.git"
  },
  "bugs": {
    "url": "https://github.com/SylphxAI/groundatlas/issues"
  },
  "keywords": [
    "agents",
    "documentation",
    "knowledge-map",
    "source-grounding",
    "cli",
    "ssot",
    "repository-map",
    "control-plane",
    "agent-tools"
  ],
  "bin": {
    "groundatlas": "dist/cli.js",
    "ga": "dist/cli.js"
  },
  "files": [
    "dist",
    "action.yml",
    "project.manifest.json",
    "examples",
    "schemas",
    "docs",
    "README.md",
    "LICENSE",
    "PROJECT.md",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/fix-shebang.mjs",
    "check": "bun run typecheck && bun test && biome check . && bun run validate:manifest && bun run validate:public-assets && bun run validate:github-action && bun run validate:workflows && bun run build && node dist/cli.js --help && node dist/cli.js manifest project.manifest.json --json && node dist/cli.js update && node dist/cli.js audit && node dist/cli.js fleet . --require-atlas --json && bun run smoke:github-action && bun run pack:dry-run && bun run pack:smoke",
    "validate:manifest": "bun scripts/validate-project-manifest.mjs",
    "dev": "bun run src/cli.ts",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "groundatlas:update": "bun run src/cli.ts update",
    "groundatlas:audit": "bun run src/cli.ts audit",
    "pack:dry-run": "npm pack --dry-run",
    "dogfood": "bun run build && node dist/cli.js update && node dist/cli.js audit && node dist/cli.js fleet . --require-atlas --json && node dist/cli.js explain \"project manifest\"",
    "pack:smoke": "node scripts/smoke-packed-package.mjs",
    "release:preflight": "node scripts/verify-release-version.mjs && node scripts/npm-registry-preflight.mjs && bun run check",
    "release:readback": "node scripts/npm-registry-readback.mjs",
    "validate:public-assets": "node scripts/validate-public-assets.mjs",
    "validate:github-action": "node scripts/validate-github-action.mjs",
    "smoke:github-action": "node scripts/smoke-github-action.mjs",
    "dogfood:external": "node scripts/dogfood-external-repo.mjs",
    "validate:workflows": "node scripts/validate-workflows.mjs",
    "dogfood:assert": "node scripts/assert-dogfood-report.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.12",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./package.json": "./package.json",
    "./schemas/project.manifest.schema.json": "./schemas/project.manifest.schema.json"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
