{
  "name": "groundatlas",
  "version": "0.1.0",
  "description": "Source-grounded knowledge maps for humans and agents.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/SylphxAI/groundatlas#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SylphxAI/groundatlas.git"
  },
  "bugs": {
    "url": "https://github.com/SylphxAI/groundatlas/issues"
  },
  "keywords": [
    "agents",
    "documentation",
    "knowledge-map",
    "source-grounding",
    "cli",
    "ssot"
  ],
  "bin": {
    "groundatlas": "dist/cli.js",
    "ga": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "PROJECT.md",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/fix-shebang.mjs",
    "check": "bun run typecheck && bun test && biome check . && bun run validate:manifest && bun run build && node dist/cli.js --help && node dist/cli.js update && node dist/cli.js audit && bun run pack:dry-run && bun run pack:smoke",
    "validate:manifest": "node scripts/validate-project-manifest.mjs",
    "dev": "bun run src/cli.ts",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "groundatlas:update": "bun run src/cli.ts update",
    "groundatlas:audit": "bun run src/cli.ts audit",
    "pack:dry-run": "npm pack --dry-run",
    "dogfood": "bun run build && node dist/cli.js update && node dist/cli.js audit && node dist/cli.js explain \"project manifest\"",
    "pack:smoke": "node scripts/smoke-packed-package.mjs",
    "release:preflight": "node scripts/verify-release-version.mjs && node scripts/npm-registry-preflight.mjs && bun run check",
    "release:readback": "node scripts/npm-registry-readback.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.12",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
