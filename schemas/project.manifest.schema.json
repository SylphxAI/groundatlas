{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://groundatlas.dev/schemas/project.manifest.schema.json",
  "title": "Project Manifest",
  "description": "Vendor-neutral per-project control file for repository identity, truth homes, public surfaces, validation commands, and adoption state.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "project"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "summary", "lifecycle"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "lifecycle": {
          "type": "string",
          "enum": [
            "idea",
            "experimental",
            "active",
            "production",
            "maintenance",
            "deprecated",
            "archived"
          ]
        },
        "visibility": {
          "type": "string",
          "enum": ["open-source", "public", "private", "internal"],
          "default": "open-source"
        },
        "repository": {
          "type": "string",
          "format": "uri"
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "truth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "humanProjectFile": {
          "type": "string",
          "default": "PROJECT.md"
        },
        "agentAdapter": {
          "type": "string",
          "default": "AGENTS.md"
        },
        "specs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "adrs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "runbooks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "name", "path"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "cli",
              "api",
              "package",
              "docs",
              "schema",
              "workflow",
              "service",
              "website",
              "other"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "command", "purpose"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "adoption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["planned", "adopted", "warning", "blocked", "exception", "unknown"]
        },
        "notes": {
          "type": "string"
        },
        "exceptions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "owner", "reason", "expiresAt"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "owner": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              },
              "expiresAt": {
                "type": "string",
                "format": "date"
              },
              "remediation": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
